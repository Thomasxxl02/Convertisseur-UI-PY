   </rect>
  </property>
  <property name="windowTitle">
   <string>Convertisseur UI → Python – macOS Designer</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
/* Style général : fond macOS */
QMainWindow, QWidget#centralwidget {
    background-color: #f5f5f7;
}

/* GroupBox arrondis style macOS */
QGroupBox {
    font-weight: 500;
    border: 1px solid #d9d9e3;
    border-radius: 12px;
    margin-top: 1.5ex;
    padding-top: 0.5ex;
    background-color: #ffffff;
    font-family: -apple-system, 'SF Pro Text', 'Helvetica Neue', sans-serif;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 16px;
    padding: 0 8px 0 8px;
    color: #1c1c1e;
    font-size: 13px;
    font-weight: 600;
}

/* LineEdit style Mac */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #c6c6c8;
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 13px;
    selection-background-color: #007aff;
}
QLineEdit:focus {
    border: 1px solid #007aff;
}
QLineEdit:hover {
    border: 1px solid #8e8e93;
}

/* Bouton principal dégradé */
QPushButton#convertButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #007aff, stop:1 #005fcb);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 8px 16px;
    font-weight: 600;
    font-size: 13px;
}
QPushButton#convertButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #0a84ff, stop:1 #0040b3);
}
QPushButton#convertButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #005fcb, stop:1 #00309c);
}

/* Boutons secondaires (Parcourir) */
QPushButton#secondaryButton {
    background: #e9e9ef;
    color: #1c1c1e;
    border: 1px solid #d4d4dc;
    border-radius: 8px;
}
QPushButton#secondaryButton:hover {
    background: #dfdfe6;
}
QPushButton#secondaryButton:pressed {
    background: #d1d1d9;
}

/* Zone de logs monospace arrondie */
QTextEdit#logTextEdit {
    background-color: #fefefe;
    border: 1px solid #d9d9e3;
    border-radius: 12px;
    font-family: 'SF Mono', 'Menlo', monospace;
    font-size: 12px;
    padding: 8px;
    color: #1c1c1e;
}
QTextEdit#logTextEdit:focus {
    border: 1px solid #007aff;
}

/* Barre de statut */
QStatusBar {
    background-color: #f5f5f7;
    color: #6c6c70;
    font-size: 11px;
}
QLabel {
    color: #2c2c2e;
    font-size: 13px;
}
QMenuBar {
    background-color: #f5f5f7;
    color: #1c1c1e;
    font-weight: 500;
}
QMenuBar::item:selected {
    background-color: #e6e6ed;
    border-radius: 4px;
}
QMenu {
    background-color: #ffffff;
    border: 1px solid #d9d9e3;
    border-radius: 8px;
}
QMenu::item:selected {
    background-color: #007aff;
    color: white;
}
   </string>
  </property>
