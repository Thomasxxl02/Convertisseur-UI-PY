# Copie ce fichier vers .env ou exporte ces variables dans ton shell.

# Cle secrete Stripe (ex: sk_test_...)
STRIPE_SECRET_KEY=

# Produit Stripe utilise pour la ligne de don
STRIPE_PRODUCT_ID=prod_UUeI06vtxJmMsz

# Tax code Stripe du produit (General - Electronically Supplied Services)
STRIPE_PRODUCT_TAX_CODE=txcd_10000000

# URLs de redirection apres paiement (optionnelles)
# STRIPE_SUCCESS_URL=http://localhost:8787/?payment=success
# STRIPE_CANCEL_URL=http://localhost:8787/?payment=cancel

# Port local du serveur de don
# DONATION_PORT=8787
